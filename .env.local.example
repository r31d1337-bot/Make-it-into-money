ANTHROPIC_API_KEY=sk-ant-...

# Stripe (use sk_test_/pk_test_ during development)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...
STRIPE_PRICE_LIFETIME=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (Resend — free 3k/month at resend.com). Required for signup
# verification and password reset. During testing, onboarding@resend.dev
# can only deliver to the email on your Resend account. To send to any
# address, verify your own domain in Resend and set EMAIL_FROM below.
RESEND_API_KEY=re_...
# Optional. Falls back to "mintr <onboarding@resend.dev>" if unset.
# EMAIL_FROM=mintr <hi@yourdomain.com>

# Set this in production so email links point at the real domain.
# NEXT_PUBLIC_SITE_URL=https://mintrapp.com

# Sentry — error tracking. Free tier covers a small SaaS comfortably.
# Get a DSN at https://sentry.io: New Project → Next.js → copy DSN.
# Without these vars, Sentry is a no-op (dev runs clean).
# NEXT_PUBLIC_SENTRY_DSN=https://...@....ingest.sentry.io/...
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=mintr
# SENTRY_AUTH_TOKEN=...   # only needed for source-map upload during build
